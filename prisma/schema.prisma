generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== Shared Reference Data =====

model Vendor {
  id    Int    @id @default(autoincrement())
  name  String @unique
  items Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("vendors")
}

model Location {
  id    Int    @id @default(autoincrement())
  name  String @unique
  items Item[]
  tools Tool[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("locations")
}

// ===== Items Domain (Consumables) =====

model ItemCategory {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  subCategories ItemSubCategory[]
  items         Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("item_categories")
}

model ItemSubCategory {
  id             Int          @id @default(autoincrement())
  name           String
  itemCategoryId Int          @map("item_category_id")
  itemCategory   ItemCategory @relation(fields: [itemCategoryId], references: [id])
  items          Item[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([name, itemCategoryId])
  @@map("item_sub_categories")
}

model Item {
  id            Int      @id @default(autoincrement())
  itemNumber    String   @unique @map("item_number")
  description   String
  unit          String?
  unitPrice     Decimal? @map("unit_price") @db.Decimal(10, 2)
  weightPerUnit Decimal? @map("weight_per_unit") @db.Decimal(10, 4)
  analysisCode  String?  @map("analysis_code")
  removeFlag    Boolean  @default(false) @map("remove_flag")
  labelPrinted  Boolean  @default(false) @map("label_printed")

  categoryId    Int?             @map("category_id")
  category      ItemCategory?    @relation(fields: [categoryId], references: [id])
  subCategoryId Int?             @map("sub_category_id")
  subCategory   ItemSubCategory? @relation(fields: [subCategoryId], references: [id])
  headType      String?          @map("head_type")
  qrCode        String?          @map("qr_code")
  imageUrl      String?          @map("image_url")
  locationId    Int?             @map("location_id")
  location      Location?        @relation(fields: [locationId], references: [id])
  vendorId      Int?             @map("vendor_id")
  vendor        Vendor?          @relation(fields: [vendorId], references: [id])

  onHand        Int       @default(0) @map("on_hand")
  minStock      Int?      @map("min_stock")
  lastQtyInOut  Int?      @map("last_qty_in_out")
  lastJobNumber String?   @map("last_job_number")
  dateAdded     DateTime? @map("date_added")
  dateDisbursed DateTime? @map("date_disbursed")
  totalCost     Decimal?  @map("total_cost") @db.Decimal(12, 2)

  transactions   ItemTransaction[]
  stockTakeItems StockTakeItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("items")
}

model ItemTransaction {
  id            Int      @id @default(autoincrement())
  itemId        Int      @map("item_id")
  item          Item     @relation(fields: [itemId], references: [id])
  jobNumber     String?  @map("job_number")
  date          DateTime
  quantityInOut Int      @map("quantity_in_or_out")
  unitPrice     Decimal? @map("unit_price") @db.Decimal(10, 2)
  totalCost     Decimal? @map("total_cost") @db.Decimal(12, 2)
  notes         String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("item_transactions")
}

// ===== Stock Take / Inventory Count =====

model StockTake {
  id        Int            @id @default(autoincrement())
  date      DateTime
  notes     String?
  status    String         @default("draft") // draft, completed, cancelled

  items StockTakeItem[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stock_takes")
}

model StockTakeItem {
  id          Int       @id @default(autoincrement())
  stockTakeId Int       @map("stock_take_id")
  stockTake   StockTake @relation(fields: [stockTakeId], references: [id], onDelete: Cascade)
  itemId      Int       @map("item_id")
  item        Item      @relation(fields: [itemId], references: [id])
  systemQty   Int       @map("system_qty")
  physicalQty Int?      @map("physical_qty")
  notes       String?

  @@unique([stockTakeId, itemId])
  @@map("stock_take_items")
}

// ===== Tools Domain (Unique Assets) =====

model ToolCategory {
  id    Int    @id @default(autoincrement())
  name  String @unique
  tools Tool[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tool_categories")
}

model Tool {
  id           Int      @id @default(autoincrement())
  toolNumber   String   @unique @map("tool_number")
  name         String
  description  String?
  brand        String?
  model        String?
  serialNumber String?  @map("serial_number")
  qrCode       String?  @map("qr_code")
  imageUrl     String?  @map("image_url")
  purchaseCost Decimal?  @map("purchase_cost") @db.Decimal(10, 2)
  notes        String?

  categoryId   Int?           @map("category_id")
  category     ToolCategory?  @relation(fields: [categoryId], references: [id])
  locationId   Int?           @map("location_id")
  location     Location?      @relation(fields: [locationId], references: [id])

  checkouts   ToolCheckout[]
  maintenance ToolMaintenanceLog[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("tools")
}

model ToolCheckout {
  id               Int       @id @default(autoincrement())
  toolId           Int       @map("tool_id")
  tool             Tool      @relation(fields: [toolId], references: [id])
  checkedOutBy     String    @map("checked_out_by")
  jobNumber        String?   @map("job_number")
  jobSite          String?   @map("job_site")
  checkedOutAt     DateTime  @default(now()) @map("checked_out_at")
  expectedReturnAt DateTime? @map("expected_return_at")
  checkedInAt      DateTime? @map("checked_in_at")
  notes            String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tool_checkouts")
}

model ToolMaintenanceLog {
  id          Int      @id @default(autoincrement())
  toolId      Int      @map("tool_id")
  tool        Tool     @relation(fields: [toolId], references: [id])
  type        String
  description String?
  date        DateTime
  performedBy String?  @map("performed_by")
  cost        Decimal? @db.Decimal(10, 2)
  notes       String?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("tool_maintenance_logs")
}
